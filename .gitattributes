# 改行コードをLFに統一（macOS/Windows混在対策）
* text=auto eol=lf

# Unity specific
*.cs text eol=lf diff=csharp
*.shader text eol=lf
*.compute text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf

# Unity YAML
*.unity text eol=lf merge=unityyamlmerge
*.prefab text eol=lf merge=unityyamlmerge
*.asset text eol=lf merge=unityyamlmerge
*.meta text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf

# Image
*.png binary
*.jpg binary
*.jpeg binary
*.psd binary
*.tga binary
*.gif binary
*.bmp binary

# Audio
*.mp3 binary
*.ogg binary
*.wav binary

# Font
*.ttf binary
*.otf binary

# 3D
*.fbx binary
*.obj binary

# Compressed
*.zip binary
*.gz binary
*.7z binary
